{
    "name": "codeigniter4/appstarter",
    "type": "project",
    "description": "API de Subastas - Backend",
    "homepage": "https://codeigniter.com",
    "license": "MIT",
   "require": {
        "php": "8.2.*", 
        "codeigniter4/framework": "^4.5",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^9.1",
        "tatter/patches": "^2.1"
    },
    "config": {
    "allow-plugins": {
        "php-http/discovery": true
    },
    "platform": {
        "php": "8.2.0"
    },
    "audit": {
        "ignore": ["PKSA-y2cr-5h3j-g3ys"]
    }
},
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit"
    }
}
